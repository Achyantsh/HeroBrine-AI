# HeroBrine AI environment template
# Copy this file to .env and fill in real values for your local or production environment.

# -----------------------------------------------------------------------------
# FastAPI configuration
# -----------------------------------------------------------------------------
# The application environment name used for behavior switches and logging.
APP_ENV=development

# Enables or disables debug mode for local development.
DEBUG=false

# The host address the FastAPI app should bind to.
HOST=0.0.0.0

# The port the FastAPI app should listen on.
PORT=8000

# The API version prefix used for routing, if versioned endpoints are introduced.
API_V1_PREFIX=/api/v1

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:3000

# -----------------------------------------------------------------------------
# PostgreSQL configuration
# -----------------------------------------------------------------------------
# The PostgreSQL server hostname or IP address.
POSTGRES_HOST=localhost

# The PostgreSQL server port.
POSTGRES_PORT=5432

# The PostgreSQL database name.
POSTGRES_DB=herobrine_ai

# The PostgreSQL username.
POSTGRES_USER=your_postgres_username

# The PostgreSQL password.
POSTGRES_PASSWORD=your_postgres_password

# The SQLAlchemy database URL used by the backend.
DATABASE_URL=postgresql+psycopg://your_postgres_username:your_postgres_password@localhost:5432/herobrine_ai

# -----------------------------------------------------------------------------
# Gemini API configuration
# -----------------------------------------------------------------------------
# Your Google Gemini API key used by the AI integration layer.
GEMINI_API_KEY=your_gemini_api_key

# The default Gemini model to use for AI requests.
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# Firebase Authentication configuration
# -----------------------------------------------------------------------------
# The Firebase project ID for your HeroBrine AI Firebase project.
FIREBASE_PROJECT_ID=your_firebase_project_id

# The Firebase service account client email.
FIREBASE_CLIENT_EMAIL=your_firebase_client_email

# The Firebase service account private key.
FIREBASE_PRIVATE_KEY=your_firebase_private_key

# The Firebase service account private key ID.
FIREBASE_PRIVATE_KEY_ID=your_firebase_private_key_id

# The Firebase service account client ID.
FIREBASE_CLIENT_ID=your_firebase_client_id

# The Firebase authentication URI used to verify tokens.
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth

# The Firebase token URI used to exchange credentials.
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token

# The Firebase certificate URL used for key discovery.
FIREBASE_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your_firebase_client_email

# -----------------------------------------------------------------------------
# Logging configuration
# -----------------------------------------------------------------------------
# The minimum logging level for the application.
LOG_LEVEL=INFO

# The output format for logs, such as json or plain text.
LOG_FORMAT=console

# The service name included in structured logs.
SERVICE_NAME=HeroBrine AI API

PROJECT_NAME=HeroBrine AI

SECRET_KEY=change_me